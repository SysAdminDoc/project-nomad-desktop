# Runtime data — never commit (would leak user data, credentials, or
# large binary blobs and could overwrite a user's local DB on pull)
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
!test_runtime/**/*.db
nomad.db
data_dir/
nomad_data/
plugins_runtime/
backups/
motion_captures/
kb_uploads/

# Secrets / credentials — never commit
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json

# Screenshots & debug images
screenshot*.png
sitroom*.png

# Test artifacts
.pytest_tmp/
test_runtime/
test_runtime_probe/
playwright-report/
test-results/
tmp/
